From 9eb2fcdd3f1cba28ef202da188ff2701077a6639 Mon Sep 17 00:00:00 2001
From: Olli Sulopuisto <dst@iki.fi>
Date: Tue, 10 Mar 2026 21:10:27 +0200
Subject: [PATCH] Add variable playback speed support

---
 music_assistant/constants.py                 | 26 +++++++++++++++++++-
 music_assistant/controllers/player_queues.py | 14 ++++++++---
 music_assistant/helpers/ffmpeg.py            | 17 +++++++++++++
 3 files changed, 53 insertions(+), 4 deletions(-)

diff --git a/music_assistant/constants.py b/music_assistant/constants.py
index eb0d7914..73287e5f 100644
--- a/music_assistant/constants.py
+++ b/music_assistant/constants.py
@@ -237,7 +237,31 @@ CONF_ENTRY_LOG_LEVEL = ConfigEntry(
     requires_reload=False,  # applied dynamically via _set_logger()
 )
 
-DEFAULT_PROVIDER_CONFIG_ENTRIES = (CONF_ENTRY_LOG_LEVEL,)
+CONF_PLAYBACK_SPEED: Final[str] = "playback_speed"
+
+CONF_ENTRY_DEFAULT_PLAYBACK_SPEED = ConfigEntry(
+    key=CONF_PLAYBACK_SPEED,
+    type=ConfigEntryType.STRING,
+    label="Default playback speed",
+    description="The default playback speed for media from this provider.",
+    options=[
+        ConfigValueOption("0.5x", "0.5"),
+        ConfigValueOption("0.75x", "0.75"),
+        ConfigValueOption("Normal (1x)", "1.0"),
+        ConfigValueOption("1.25x", "1.25"),
+        ConfigValueOption("1.5x", "1.5"),
+        ConfigValueOption("1.75x", "1.75"),
+        ConfigValueOption("2x", "2.0"),
+    ],
+    default_value="1.0",
+    advanced=True,
+    requires_reload=False,
+)
+
+DEFAULT_PROVIDER_CONFIG_ENTRIES = (
+    CONF_ENTRY_LOG_LEVEL,
+    CONF_ENTRY_DEFAULT_PLAYBACK_SPEED,
+)
 DEFAULT_CORE_CONFIG_ENTRIES = (CONF_ENTRY_LOG_LEVEL,)
 
 # some reusable player config entries
diff --git a/music_assistant/controllers/player_queues.py b/music_assistant/controllers/player_queues.py
index cf2d9746..cd84a064 100644
--- a/music_assistant/controllers/player_queues.py
+++ b/music_assistant/controllers/player_queues.py
@@ -73,6 +73,7 @@ from music_assistant.constants import (
     PLAYBACK_REPORT_INTERVAL_SECONDS,
     PLAYLIST_MEDIA_TYPES,
     VERBOSE_LOG_LEVEL,
+    CONF_PLAYBACK_SPEED,
     PlaylistPlayableItem,
 )
 from music_assistant.controllers.players.controller import IN_QUEUE_COMMAND
@@ -443,10 +444,10 @@ class PlayerQueuesController(CoreController):
         the speed will be set for the current item in the queue.
 
         :param queue_id: queue_id of the queue to configure.
-        :param speed: playback speed multiplier (0.5 to 2.0). 1.0 = normal speed.
+        :param speed: playback speed multiplier (0.2 to 3.0). 1.0 = normal speed.
         """
-        if not (0.5 <= speed <= 2.0):
-            raise InvalidDataError(f"Playback speed must be between 0.5 and 2.0, got {speed}")
+        if not (0.2 <= speed <= 3.0):
+            raise InvalidDataError(f"Playback speed must be between 0.2 and 3.0, got {speed}")
         queue = self._queues[queue_id]
         if not queue.current_item:
             raise QueueEmpty("Cannot set playback speed: queue is empty")
@@ -1110,6 +1111,13 @@ class PlayerQueuesController(CoreController):
                     seek_position=seek_position if attempt == 0 else 0,
                     fade_in=fade_in if attempt == 0 else False,
                 )
+                # handle default playback speed from provider
+                if queue_item.extra_attributes.get("playback_speed") is None:
+                    if provider := self.mass.get_provider(queue_item.media_item.provider):
+                        default_speed = provider.config.get_value(CONF_PLAYBACK_SPEED)
+                        if default_speed and default_speed != "1.0":
+                            queue_item.extra_attributes["playback_speed"] = float(default_speed)
+
                 # if we reach this point, loading the item succeeded, break the loop
                 queue.current_index = index
                 queue.current_item = queue_item
diff --git a/music_assistant/helpers/ffmpeg.py b/music_assistant/helpers/ffmpeg.py
index f886e576..515442cc 100644
--- a/music_assistant/helpers/ffmpeg.py
+++ b/music_assistant/helpers/ffmpeg.py
@@ -394,6 +394,23 @@ def get_ffmpeg_args(  # noqa: PLR0915
             *filter_params,
         ]
 
+    # handle playback speed with atempo filter
+    if (atempo_filter := next((x for x in filter_params if x.startswith("atempo=")), None)) and (
+        "-filter_complex" not in extra_args
+    ):
+        # atempo filter has a range of [0.5, 2.0]
+        # if we want a speed outside this range, we need to chain multiple filters
+        speed = float(atempo_filter.split("=")[1])
+        filter_params.remove(atempo_filter)
+        if speed != 1.0:
+            while speed < 0.5:
+                filter_params.append("atempo=0.5")
+                speed /= 0.5
+            while speed > 2.0:
+                filter_params.append("atempo=2.0")
+                speed /= 2.0
+            filter_params.append(f"atempo={speed}")
+
     # determine if we need to do resampling (or dithering)
     if input_format.sample_rate != output_format.sample_rate or (
         input_format.bit_depth > 16 and output_format.bit_depth == 16
