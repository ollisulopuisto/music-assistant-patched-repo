+        else:
+            url = f"{ha_url}{path}"
+
+        # Use HASSIO_TOKEN when running as addon (token config is None)
+        token = (
+            self.config.get_value(CONF_AUTH_TOKEN)
+            or os.environ.get("SUPERVISOR_TOKEN")
+            or os.environ.get("HASSIO_TOKEN")
+        )
