+    async def resolve_image(self, path: str) -> bytes:
+        """Resolve an image from an image path."""
+        ha_url = cast("str", self.config.get_value(CONF_URL)).rstrip("/")
+        if ha_url.endswith("/api") and path.startswith("/api/"):
